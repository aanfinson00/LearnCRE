# Cloud sync (optional). Leave both unset to run the app fully local-first.
#
# To enable:
#   1. Create a Supabase project (free tier) at https://supabase.com
#   2. Apply the migration in supabase/migrations/0001_initial.sql via the
#      SQL editor or `supabase migration up` (Supabase CLI)
#   3. Copy this file to .env, fill in the values from your project settings
#      (Settings → API → URL + anon/public key)
#   4. Restart the dev server / rebuild
#
# When unset, the app runs single-user local-storage only and the sign-in
# UI on the Profile screen explains how to enable cloud.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
